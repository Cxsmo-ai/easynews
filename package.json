{
  "_manifest": {
    "name": "Easynews",
    "id": "com.easynews.syncler",
    "version": 1,
    "classPath": "",
    "permaUrl": "https://cxsmo-ai.github.io/easynews/package.json",
    "type": "express",
    "accounts": [
      {
        "alias": "easynews",
        "branding": {
          "name": "Easynews",
          "website": "https://easynews.com",
          "logo": "https://www.easynews.com/assets/img/shared/en-logo.png"
        },
        "auth": {
          "type": "basic",
          "allowedDomains": [
            "easynews.com"
          ],
          "inject": {
            "headers": {
              "Authorization": "Basic {managedAccounts.easynews.basicToken}"
            }
          }
        },
        "verification": {
          "url": "https://account.easynews.com/editinfo.php",
          "method": "GET",
          "responseType": "json",
          "extract": {
            "username": {
              "type": "regex",
              "value": ">Username</td><td style=\\\"vertical-align: bottom;\\\" >(.+?)</td>"
            }
          }
        }
      }
    ]
  },
  "easynews": {
    "name": "Easynews",
    "base_url": "https://b89262c192b0-stremio-easynews-addon.baby-beamup.club",
    "response_type": "json",
    "movie": {
      "query": "/%7B%22username%22%3A%22{managedAccounts.easynews.username}%22%2C%22password%22%3A%22{managedAccounts.easynews.password}%22%2C%22sort1%22%3A%22Size%22%2C%22sort1Direction%22%3A%22Descending%22%2C%22sort2%22%3A%22Relevance%22%2C%22sort2Direction%22%3A%22Descending%22%2C%22sort3%22%3A%22Date%20%26%20Time%22%2C%22sort3Direction%22%3A%22Descending%22%7D/stream/movie/{query}.json",
      "keywords": "{imdbId}"
    },
    "episode": {
      "query": "/%7B%22username%22%3A%22{managedAccounts.easynews.username}%22%2C%22password%22%3A%22{managedAccounts.easynews.password}%22%2C%22sort1%22%3A%22Size%22%2C%22sort1Direction%22%3A%22Descending%22%2C%22sort2%22%3A%22Relevance%22%2C%22sort2Direction%22%3A%22Descending%22%2C%22sort3%22%3A%22Date%20%26%20Time%22%2C%22sort3Direction%22%3A%22Descending%22%7D/stream/series/{query}:{season}:{episode}.json",
      "keywords": "{showImdbId}"
    },
    "anime": {
      "query": "/%7B%22username%22%3A%22{managedAccounts.easynews.username}%22%2C%22password%22%3A%22{managedAccounts.easynews.password}%22%2C%22sort1%22%3A%22Size%22%2C%22sort1Direction%22%3A%22Descending%22%2C%22sort2%22%3A%22Relevance%22%2C%22sort2Direction%22%3A%22Descending%22%2C%22sort3%22%3A%22Date%20%26%20Time%22%2C%22sort3Direction%22%3A%22Descending%22%7D/stream/anime/{query}:{season}:{episode}.json",
      "keywords": "{showImdbId}"
    },
    "json_format": {
      "results": "streams",
      "url": "url",
      "title": "description",
      "title:ops": [
        {
          "name": "regex",
          "params": [
            "(.+?)\\n"
          ]
        }
      ],
      "size": "behaviorHints.videoSize",
      "host": "url",
      "host:ops": [
        {
          "name": "regex",
          "params": [
            "http(?:s|)://(.+)/"
          ]
        }
      ],
      "playbackFileName": "name",
      "playbackFileName:ops": [
        {
          "name": "regex",
          "params": [
            "^(.+)\\\\n"
          ]
        }
      ],
      "playbackFileSize": "behaviorHints.videoSize"
    }
  }
}
