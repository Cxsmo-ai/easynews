{
  "easynews": {
    "name": "Easynews",
    "enabled": true,
    "languages": [
      "en"
    ],
    "base_url": "https://members.easynews.com",
    "response_type": "text",
    "movie": {
      "query": "/1.0/global5/search.html?gps={query}&fex=m4v,3gp,mov,divx,xvid,wmv,avi,mpg,mpeg,mp4,mkv,avc,flv,webm&fty[]=VIDEO&spamf=1&u=1&sb=1&pby=100&pno=1&sS=0&s1=dsize&s1d=-&safeO=0",
      "keywords": "{title} {year}"
    },
    "episode": {
      "query": "/1.0/global5/search.html?gps={query}&fex=m4v,3gp,mov,divx,xvid,wmv,avi,mpg,mpeg,mp4,mkv,avc,flv,webm&fty[]=VIDEO&spamf=1&u=1&sb=1&pby=100&pno=1&sS=0&s1=dsize&s1d=-&safeO=0",
      "keywords": "{title} {episodeCode}"
    },
    "anime": {
      "query": "/1.0/global5/search.html?gps={query}&fex=m4v,3gp,mov,divx,xvid,wmv,avi,mpg,mpeg,mp4,mkv,avc,flv,webm&fty[]=VIDEO&spamf=1&u=1&sb=1&pby=100&pno=1&sS=0&s1=dsize&s1d=-&safeO=0",
      "keywords": "{title} {episodeCode}"
    },
    "html_parser": {
      "row": "doc.querySelectorAll('tr[class^=\"rRow\"]')",
      "url": "row.querySelector('td.subject a[href*=\"/dl/\"]').getAttribute('href')",
      "title": "row.querySelector('td.subject a[href*=\"/dl/\"]').getAttribute('href').split('/').pop().split('?')[0]",
      "size": "row.querySelector('td.fSize').textContent.trim()"
    },
    "original_package": "Easynews"
  }
}
